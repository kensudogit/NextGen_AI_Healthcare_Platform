# Database (Spring Boot / JDBC)
DATABASE_URL=jdbc:postgresql://localhost:5436/nghealth
DATABASE_USER=nghealth
DATABASE_PASSWORD=nghealth_dev

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS
CORS_ORIGINS=http://localhost:3010

# OAuth2 / Keycloak
OAUTH_ENABLED=false
OAUTH2_ISSUER_URI=http://localhost:8080/realms/nghealth
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=nghealth
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=nghealth-frontend

# AWS S3 (LocalStack in Docker)
STORAGE_USE_S3=true
AWS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET=nghealth-dicom

# Hospital
HOSPITAL_NAME=NextGen General Hospital
